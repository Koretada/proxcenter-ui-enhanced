generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Connection {
  id            String        @id @default(cuid())
  tenantId      String        @default("default") @map("tenant_id")
  name          String
  type          String        @default("pve")
  baseUrl       String
  behindProxy   Boolean       @default(false)
  insecureTLS   Boolean       @default(false)
  hasCeph       Boolean       @default(false)
  latitude      Float?
  longitude     Float?
  locationLabel String?
  apiTokenEnc   String
  sshEnabled    Boolean       @default(false)
  sshPort       Int           @default(22)
  sshUser       String        @default("root")
  sshAuthMethod String?
  sshKeyEnc     String?
  sshPassEnc    String?
  sshUseSudo    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  hosts         ManagedHost[]
}

model ManagedHost {
  id           String      @id @default(cuid())
  tenantId     String      @default("default") @map("tenant_id")
  connectionId String?
  node         String
  ip           String?
  sshAddress   String?
  displayName  String?
  enabled      Boolean     @default(true)
  notes        String?
  description  String?
  tags         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  connection   Connection? @relation(fields: [connectionId], references: [id])

  @@unique([connectionId, node])
}

model DashboardLayout {
  id        String   @id @default(cuid())
  tenantId  String   @default("default") @map("tenant_id")
  userId    String   @default("default")
  name      String   @default("custom")
  widgets   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model Alert {
  id             String    @id @default(cuid())
  tenantId       String    @default("default") @map("tenant_id")
  fingerprint    String
  severity       String
  message        String
  source         String
  sourceType     String    @default("pve") @map("source_type")
  entityType     String?   @map("entity_type")
  entityId       String?   @map("entity_id")
  entityName     String?   @map("entity_name")
  metric         String?
  currentValue   Float?    @map("current_value")
  threshold      Float?
  status         String    @default("active")
  occurrences    Int       @default(1)
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  acknowledgedBy String?   @map("acknowledged_by")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, fingerprint])
  @@index([status])
  @@index([severity])
  @@index([source])
  @@index([lastSeenAt])
  @@index([status, severity, lastSeenAt])
  @@map("alerts")
}

model CustomImage {
  id                String   @id @default(cuid())
  tenantId          String   @default("default") @map("tenant_id")
  slug              String
  name              String
  vendor            String   @default("custom")
  version           String   @default("")
  arch              String   @default("amd64")
  format            String   @default("qcow2")
  sourceType        String   @default("url") @map("source_type")
  downloadUrl       String?  @map("download_url")
  checksumUrl       String?  @map("checksum_url")
  volumeId          String?  @map("volume_id")
  defaultDiskSize   String   @default("20G") @map("default_disk_size")
  minMemory         Int      @default(512) @map("min_memory")
  recommendedMemory Int      @default(2048) @map("recommended_memory")
  minCores          Int      @default(1) @map("min_cores")
  recommendedCores  Int      @default(2) @map("recommended_cores")
  ostype            String   @default("l26")
  tags              String?
  createdBy         String?  @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@map("custom_images")
}

model Blueprint {
  id          String   @id @default(cuid())
  tenantId    String   @default("default") @map("tenant_id")
  name        String
  description String?
  imageSlug   String   @map("image_slug")
  hardware    String
  cloudInit   String?  @map("cloud_init")
  tags        String?
  isPublic    Boolean  @default(true) @map("is_public")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blueprints")
}

model Deployment {
  id            String    @id @default(cuid())
  tenantId      String    @default("default") @map("tenant_id")
  blueprintId   String?   @map("blueprint_id")
  blueprintName String?   @map("blueprint_name")
  connectionId  String    @map("connection_id")
  node          String
  vmid          Int
  vmName        String?   @map("vm_name")
  imageSlug     String?   @map("image_slug")
  config        String?
  status        String    @default("pending")
  currentStep   String?   @map("current_step")
  error         String?
  taskUpid      String?   @map("task_upid")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([connectionId])
  @@map("deployments")
}

model MigrationJob {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default") @map("tenant_id")
  sourceConnectionId String    @map("source_connection_id")
  sourceVmId         String    @map("source_vm_id")
  sourceVmName       String?   @map("source_vm_name")
  sourceHost         String?   @map("source_host")
  targetConnectionId String    @map("target_connection_id")
  targetNode         String    @map("target_node")
  targetStorage      String    @map("target_storage")
  targetVmid         Int?      @map("target_vmid")
  config             String?
  status             String    @default("pending")
  currentStep        String?   @map("current_step")
  progress           Int       @default(0)
  totalDisks         Int?      @map("total_disks")
  currentDisk        Int?      @map("current_disk")
  bytesTransferred   BigInt?   @map("bytes_transferred")
  totalBytes         BigInt?   @map("total_bytes")
  transferSpeed      String?   @map("transfer_speed")
  error              String?
  logs               String?
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  createdBy          String?   @map("created_by")

  @@index([status])
  @@index([sourceConnectionId])
  @@index([targetConnectionId])
  @@map("migration_jobs")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model alert_instances {
  id              String?     @id
  rule_id         String
  status          String      @default("active")
  entity_type     String
  entity_id       String
  entity_name     String?
  node            String?
  connection_id   String?
  connection_name String?
  metric          String
  current_value   Float?
  threshold       Float
  severity        String
  message         String
  triggered_at    String
  resolved_at     String?
  acknowledged_at String?
  acknowledged_by String?
  tenant_id       String      @default("default")
  alert_rules     alert_rules @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_alert_instances_tenant")
  @@index([entity_type, entity_id], map: "idx_alert_instances_entity")
  @@index([triggered_at], map: "idx_alert_instances_triggered_at")
  @@index([rule_id], map: "idx_alert_instances_rule_id")
  @@index([status], map: "idx_alert_instances_status")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model alert_rules {
  id              String?           @id
  name            String
  description     String?
  enabled         Int               @default(1)
  metric          String
  operator        String
  threshold       Float
  duration        Int               @default(0)
  severity        String            @default("warning")
  scope_type      String            @default("all")
  scope_target    String?
  created_at      String
  updated_at      String
  tenant_id       String            @default("default")
  alert_instances alert_instances[]

  @@index([tenant_id], map: "idx_alert_rules_tenant")
  @@index([metric], map: "idx_alert_rules_metric")
  @@index([enabled], map: "idx_alert_rules_enabled")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model audit_logs {
  id            String? @id
  timestamp     String
  user_id       String?
  user_email    String?
  action        String
  category      String
  resource_type String?
  resource_id   String?
  resource_name String?
  details       String?
  ip_address    String?
  user_agent    String?
  status        String  @default("success")
  error_message String?
  tenant_id     String  @default("default")

  @@index([tenant_id], map: "idx_audit_logs_tenant")
  @@index([resource_type, resource_id], map: "idx_audit_logs_resource")
  @@index([category], map: "idx_audit_logs_category")
  @@index([action], map: "idx_audit_logs_action")
  @@index([user_id], map: "idx_audit_logs_user_id")
  @@index([timestamp], map: "idx_audit_logs_timestamp")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model compliance_profile_checks {
  id                  String?             @id
  profile_id          String
  check_id            String
  enabled             Int                 @default(1)
  weight              Float               @default(1.0)
  control_ref         String?
  category            String?
  tenant_id           String              @default("default")
  compliance_profiles compliance_profiles @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenant_id], map: "idx_compliance_profile_checks_tenant")
  @@index([profile_id], map: "idx_compliance_profile_checks_profile")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model compliance_profiles {
  id                        String?                     @id
  name                      String
  description               String?
  framework_id              String?
  is_active                 Int                         @default(0)
  connection_id             String?
  created_by                String?
  created_at                String
  updated_at                String
  tenant_id                 String                      @default("default")
  compliance_profile_checks compliance_profile_checks[]

  @@index([tenant_id], map: "idx_compliance_profiles_tenant")
  @@index([connection_id], map: "idx_compliance_profiles_connection")
  @@index([is_active], map: "idx_compliance_profiles_active")
  @@ignore
}

model favorites {
  id            String? @id
  user_id       String
  vm_key        String
  connection_id String
  node          String
  vm_type       String
  vmid          String
  vm_name       String?
  created_at    String
  tenant_id     String  @default("default")

  @@unique([user_id, vm_key], map: "sqlite_autoindex_favorites_2")
  @@index([tenant_id], map: "idx_favorites_tenant")
  @@index([vm_key], map: "idx_favorites_vm_key")
  @@index([user_id], map: "idx_favorites_user_id")
}

model health_score_history {
  id            String? @id
  date          String  @unique(map: "sqlite_autoindex_health_score_history_2")
  score         Int
  cpu_pct       Float?
  ram_pct       Float?
  storage_pct   Float?
  details       String?
  connection_id String?
  created_at    String
  tenant_id     String  @default("default")

  @@index([tenant_id], map: "idx_health_score_history_tenant")
  @@index([date], map: "idx_health_score_date")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ldap_config {
  id                 String? @id @default("default")
  enabled            Int     @default(0)
  url                String
  bind_dn            String?
  bind_password_enc  String?
  base_dn            String
  user_filter        String  @default("(uid={{username}})")
  email_attribute    String  @default("mail")
  name_attribute     String  @default("cn")
  tls_insecure       Int     @default(0)
  created_at         String
  updated_at         String
  tenant_id          String  @default("default")
  start_tls          Int     @default(0)
  group_attribute    String? @default("memberOf")
  group_role_mapping String? @default("{}")
  default_role       String? @default("role_viewer")

  @@index([tenant_id], map: "idx_ldap_config_tenant")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model oidc_config {
  id                 String? @id @default("default")
  enabled            Int     @default(0)
  provider_name      String  @default("SSO")
  issuer_url         String  @default("")
  client_id          String  @default("")
  client_secret_enc  String?
  scopes             String  @default("openid profile email")
  authorization_url  String?
  token_url          String?
  userinfo_url       String?
  claim_email        String  @default("email")
  claim_name         String  @default("name")
  claim_groups       String? @default("groups")
  auto_provision     Int     @default(1)
  default_role       String  @default("viewer")
  group_role_mapping String? @default("{}")
  created_at         String
  updated_at         String
  tenant_id          String  @default("default")

  @@index([tenant_id], map: "idx_oidc_config_tenant")
  @@ignore
}

model rbac_permissions {
  id                    String?                 @id
  name                  String                  @unique(map: "sqlite_autoindex_rbac_permissions_2")
  category              String
  description           String?
  is_dangerous          Int                     @default(0)
  created_at            String                  @default("CURRENT_TIMESTAMP")
  rbac_role_permissions rbac_role_permissions[]
  rbac_user_permissions rbac_user_permissions[] @ignore

  @@index([category], map: "idx_rbac_permissions_category")
}

model rbac_role_permissions {
  role_id          String
  permission_id    String
  rbac_permissions rbac_permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rbac_roles       rbac_roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model rbac_roles {
  id                    String?                 @id
  name                  String                  @unique(map: "sqlite_autoindex_rbac_roles_2")
  description           String?
  is_system             Int                     @default(0)
  color                 String?                 @default("#6366f1")
  created_at            String
  updated_at            String
  rbac_role_permissions rbac_role_permissions[]
  rbac_user_roles       rbac_user_roles[]       @ignore

  @@index([is_system], map: "idx_rbac_roles_system")
  @@index([name], map: "idx_rbac_roles_name")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model rbac_user_permissions {
  id                                            String?          @id
  user_id                                       String
  permission_id                                 String
  scope_type                                    String           @default("global")
  scope_target                                  String?
  tenant_id                                     String           @default("default")
  granted_by                                    String?
  granted_at                                    String
  expires_at                                    String?
  users_rbac_user_permissions_granted_byTousers users?           @relation("rbac_user_permissions_granted_byTousers", fields: [granted_by], references: [id], onUpdate: NoAction)
  rbac_permissions                              rbac_permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_rbac_user_permissions_user_idTousers    users            @relation("rbac_user_permissions_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([scope_type, scope_target], map: "idx_rbac_user_perms_scope")
  @@index([user_id], map: "idx_rbac_user_perms_user")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model rbac_user_roles {
  id                                      String?    @id
  user_id                                 String
  role_id                                 String
  scope_type                              String     @default("global")
  scope_target                            String?
  tenant_id                               String     @default("default")
  granted_by                              String?
  granted_at                              String
  expires_at                              String?
  users_rbac_user_roles_granted_byTousers users?     @relation("rbac_user_roles_granted_byTousers", fields: [granted_by], references: [id], onUpdate: NoAction)
  rbac_roles                              rbac_roles @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_rbac_user_roles_user_idTousers    users      @relation("rbac_user_roles_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([scope_type, scope_target], map: "idx_rbac_user_roles_scope")
  @@index([role_id], map: "idx_rbac_user_roles_role")
  @@index([user_id], map: "idx_rbac_user_roles_user")
  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model security_policies {
  id                             String? @id @default("default")
  password_min_length            Int     @default(8)
  password_require_uppercase     Int     @default(0)
  password_require_lowercase     Int     @default(0)
  password_require_numbers       Int     @default(0)
  password_require_special       Int     @default(0)
  session_timeout_minutes        Int     @default(43200)
  session_max_concurrent         Int     @default(0)
  login_max_failed_attempts      Int     @default(0)
  login_lockout_duration_minutes Int     @default(15)
  audit_retention_days           Int     @default(90)
  audit_auto_cleanup             Int     @default(0)
  updated_at                     String
  updated_by                     String?
  tenant_id                      String  @default("default")

  @@index([tenant_id], map: "idx_security_policies_tenant")
  @@ignore
}

model sessions {
  id         String? @id
  user_id    String
  token      String  @unique(map: "sqlite_autoindex_sessions_2")
  expires_at String
  created_at String
  ip_address String?
  user_agent String?
  users      users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_sessions_expires")
  @@index([token], map: "idx_sessions_token")
  @@index([user_id], map: "idx_sessions_user_id")
}

model settings {
  key        String
  tenant_id  String  @default("default")
  value      String
  updated_at String? @default("CURRENT_TIMESTAMP")

  @@id([key, tenant_id])
  @@unique([key, tenant_id], map: "idx_settings_key_tenant")
}

model tenants {
  id           String?        @id
  slug         String         @unique(map: "sqlite_autoindex_tenants_2")
  name         String
  description  String?
  enabled      Int            @default(1)
  settings     String?
  created_by   String?
  created_at   String
  updated_at   String
  user_tenants user_tenants[]

  @@index([slug], map: "idx_tenants_slug")
}

model user_tenants {
  user_id    String
  tenant_id  String
  is_default Int     @default(0)
  joined_at  String
  tenants    tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, tenant_id])
  @@index([tenant_id], map: "idx_user_tenants_tenant")
  @@index([user_id], map: "idx_user_tenants_user")
}

model users {
  id                                                            String?                 @id
  email                                                         String                  @unique(map: "idx_users_email")
  password                                                      String?
  name                                                          String?
  avatar                                                        String?
  role                                                          String                  @default("viewer")
  auth_provider                                                 String                  @default("credentials")
  ldap_dn                                                       String?
  enabled                                                       Int                     @default(1)
  last_login_at                                                 String?
  created_at                                                    String
  updated_at                                                    String
  oidc_sub                                                      String?
  tenant_id                                                     String                  @default("default")
  rbac_user_permissions_rbac_user_permissions_granted_byTousers rbac_user_permissions[] @relation("rbac_user_permissions_granted_byTousers") @ignore
  rbac_user_permissions_rbac_user_permissions_user_idTousers    rbac_user_permissions[] @relation("rbac_user_permissions_user_idTousers") @ignore
  rbac_user_roles_rbac_user_roles_granted_byTousers             rbac_user_roles[]       @relation("rbac_user_roles_granted_byTousers") @ignore
  rbac_user_roles_rbac_user_roles_user_idTousers                rbac_user_roles[]       @relation("rbac_user_roles_user_idTousers") @ignore
  sessions                                                      sessions[]
  user_tenants                                                  user_tenants[]

  @@index([tenant_id], map: "idx_users_tenant")
}
